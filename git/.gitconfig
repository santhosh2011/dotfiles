# User identity is sourced from ~/.gitconfig.local so it stays out of this
# public dotfiles repo. Create that file with your [user] block.
[include]
    path = ~/.gitconfig.local

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
