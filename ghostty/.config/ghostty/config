font-family = "JetBrainsMono Nerd Font"
font-size = 11

# Ensure tmux (launched directly below) and its plugins can find Homebrew bins
env = PATH=/Users/santhoshthota/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin

# Launch every new window inside tmux
# Attaches to the "main" session or creates it if missing
command = "/opt/homebrew/bin/tmux new-session -A -s main"

# Create a new tmux session (prompts for a name)
keybind = cmd+shift+n=text:\x13N
# Switch tmux sessions (opens choose-tree picker)
keybind = cmd+shift+s=text:\x13s
