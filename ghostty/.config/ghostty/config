font-family = "JetBrainsMono Nerd Font"
font-size = 13

# Match tmux's Catppuccin Mocha palette so the window doesn't flash on launch.
# Override the background to Catppuccin's darkest shade (Crust) for a near-black
# look closer to Terminal.app, while keeping ANSI colors consistent with tmux.
theme = Catppuccin Mocha
background = 11111b

# Ensure tmux (launched directly below) and its plugins can find Homebrew bins
env = PATH=~/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin

# Launch every new window inside tmux
# Attaches to the "main" session or creates it if missing
command = "/opt/homebrew/bin/tmux new-session -A -s main"

# Create a new tmux session (prompts for a name)
keybind = cmd+shift+n=text:\x13N
# Switch tmux sessions (opens choose-tree picker)
keybind = cmd+shift+s=text:\x13s
